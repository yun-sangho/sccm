{
  "description": "Sangho Claude Code Hooks - 보안 가드",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/guard-bash.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/guard-secrets.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
